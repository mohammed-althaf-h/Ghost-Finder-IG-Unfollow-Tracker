{
  "manifest_version": 3,
  "name": "Ghost Finder — IG Unfollow Tracker",
  "version": "1.4",
  "description": "Find who unfollowed your friend on Instagram. Persistent multi-session scraping with ghost detection.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
